{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=60, stale-while-revalidate=300"
                }
            ]
        }
    ],


    "version": 2,
    "builds": [
        {
            "src": "server/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "client/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/server/index.js"
        },
        {
            "src": "/css/(.*)",
            "dest": "/client/css/$1"
        },
        {
            "src": "/js/(.*)",
            "dest": "/client/js/$1"
        },
        {
            "src": "/img/(.*)",
            "dest": "/client/img/$1"
        },
        {
            "src": "/modpacks.html",
            "dest": "/client/modpacks.html"
        },
        {
            "src": "/submit.html",
            "dest": "/client/submit.html"
        },
        {
            "src": "/my-submissions.html",
            "dest": "/client/my-submissions.html"
        },
        {
            "src": "/disclaimer.html",
            "dest": "/client/disclaimer.html"
        },
        {
            "src": "/(.*)",
            "dest": "/client/index.html"
        }
    ]
}
